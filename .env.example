# API key clients must send as "Authorization: Bearer ..." (leave empty to disable auth)
API_KEY=00000000000000000000000000000000

# ── ChatGPT authentication ───────────────────────────────────────────────────
# Auth is your chatgpt.com session cookie (no email/OTP login).
#
# CASE A — single token cookie:
#   Set CHATGPT_SESSION_TOKEN to the value of "__Secure-next-auth.session-token".
#
# CASE B — chunked token (you have __Secure-next-auth.session-token.0 AND .1):
#   A single value can't represent it. Leave CHATGPT_SESSION_TOKEN empty and paste
#   the WHOLE cookie string into CHATGPT_COOKIES instead. Easiest way to get it:
#   DevTools → Network → click any chatgpt.com request → Headers → Request Headers
#   → copy the entire "Cookie:" value.
#
# Treat these like passwords. With a persisted browser profile (BROWSER_PROFILE_DIR is set
# in docker-compose, mounted on the ripgpt-profile volume) the cookie is a ONE-TIME
# BOOTSTRAP: paste it for the first run, then the profile keeps ChatGPT's auto-renewed
# session across restarts — no manual refresh for 24/7 use. Only re-paste if the dashboard
# shows LOGGED OUT (e.g. after a password change or long downtime).
CHATGPT_SESSION_TOKEN=
CHATGPT_COOKIES=

# Cloudflare cookies (cf_clearance, __cf_bm…) are skipped by default because they're
# bound to the UA+IP that earned them. Set true only if you run on the SAME machine
# and matched the browser/UA to where you copied them from.
INJECT_CF_COOKIES=false

# ── Public URL ───────────────────────────────────────────────────────────────
# Origin used to build hosted image URLs (/images/...), must be reachable from the
# client's browser. Local default below; for a public deploy set your domain.
PUBLIC_BASE_URL=http://localhost:8850
# PUBLIC_BASE_URL=https://ripgpt.nmt.ovh

# ── Public exposure via Cloudflare Tunnel (optional) ─────────────────────────
# Run with:  docker compose --profile tunnel up -d
# Cloudflare → Zero Trust → Networks → Tunnels → Create (Cloudflared) → copy the token
# here. Then add a Public Hostname  ripgpt.nmt.ovh → HTTP → http://api:8850.
TUNNEL_TOKEN=

# ── OpenWebUI ────────────────────────────────────────────────────────────────
# Web UI at http://localhost:3001 (it talks to ripgpt as an OpenAI backend, reusing
# API_KEY above). Set false to skip the login/signup screen for local-only use.
WEBUI_AUTH=true
